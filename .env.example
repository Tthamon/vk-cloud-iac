# .env.example
# VK Cloud Infrastructure
# Скопируйте этот файл как .env
# Заполните и раскомментируйте по очереди своими значениями переменные команд export 


# Общие настройки
# export PROJECT_NAME="my-project"
# export MY_IP="<my_ip_address>/32"
# export DB_PASSWORD="MySecurePass123!"
# export IMAGE_NAME="web-server-base"

# S3 Бакет для Terraform State
# export BUCKET_NAME="my-project-terraform-state"

# Учётные данные VK Cloud (S3)
# export S3_ACCESS_KEY="ваш_access_ключ"
# export S3_SECRET_KEY="ваш_secret_ключ"

# Учётные данные VK Cloud (провайдер)
# export OS_USERNAME="ваш_логин"
# export OS_PASSWORD="ваш_пароль"
# export OS_PROJECT_ID="ваш_project_id"
export OS_USER_DOMAIN_NAME="users"
export OS_REGION_NAME="RegionOne"
export OS_AUTH_URL="https://msk.cloud.vk.com/infra/identity/v3/"

# Packer переменные (с префиксом PKR_VAR_)
export PKR_VAR_os_username="$OS_USERNAME"
export PKR_VAR_os_password="$OS_PASSWORD"
export PKR_VAR_os_project_id="$OS_PROJECT_ID"
export PKR_VAR_image_name="$IMAGE_NAME"

# Terraform переменные (с префиксом TF_VAR_)
export TF_VAR_project_name="$PROJECT_NAME"
export TF_VAR_my_ip="$MY_IP"
export TF_VAR_bucket_name="$BUCKET_NAME"
export TF_VAR_s3_access_key="$S3_ACCESS_KEY"
export TF_VAR_s3_secret_key="$S3_SECRET_KEY"
export TF_VAR_db_password="$DB_PASSWORD"
export TF_VAR_image_name="$IMAGE_NAME"
# export TF_VAR_ssh_public_key="$(cat <path_to_my_ssh_key>.pub)"